{
  "description": "Autoresearch — autonomous iterative improvement with git-tracked experiments",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/run_hook.sh\" session_start.py",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/run_hook.sh\" on_stop.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
